.table-responsive
  %table.table.table-hover.table-striped
    %thead
      %tr
        %th= sort_link @search, :name, "Name"
        %th= sort_link @search, :program_type, "Type"
        %th= sort_link @search, :last_run, "Last Run"
        %th.text-end= sort_link @search, :runtime, "Runtime"
        %th.text-end Thread Utilization
        %th.text-center= sort_link @search, :enabled, "Status"
        %th
    %tbody
      - @programs.each do |program|
        %tr.program{ id: dom_id(program), data: { program: program.json_data }}
          %td= link_to program.name, program, data: { turbo_frame: "_top" }
          %td
            - if program.program_type_repeated?
              #{program.program_type_to_human}(#{program.repeat_every}s)
            - else
              = program.program_type_to_human
          %td.last-run
          %td.text-end
            %span.runtime> !
            ms
          %td.text-end
            %span.thread-utilisation> !
            \%
          %td.text-nowrap.text-center
            = link_to fa_icon("toggle-on"), set_program_path(program, program: { enabled: false }), class: "btn btn-sm btn-success toggle-on", data: { turbo_method: :patch }
            = link_to fa_icon("toggle-off"), set_program_path(program, program: { enabled: true }), class: "btn btn-sm btn-warning toggle-off", data: { turbo_method: :patch }
          %td.text-nowrap.text-end.actions
            = link_to fa_icon("play"), run_program_path(program), class: "ml btn btn-sm btn-info", title: "Test run", data: { turbo_method: :patch, turbo_confirm: "Are you sure?" }
            = link_to fa_icon("copy"), new_program_path(program_id: program), class: "ml btn btn-sm btn-primary", data: { turbo_frame: "_top" }
            = link_to fa_icon("pencil-alt"), edit_program_path(program), title: "Edit", class: "btn btn-sm btn-primary", data: { turbo_frame: "_top" }
            = link_to fa_icon("trash"), program, class: "ml btn btn-sm btn-danger", data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }

.page-pagination
  .pagination-description
    = page_entries_info @programs
  = paginate @programs
