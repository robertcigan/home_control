.nested-fields{ data: { new_record: f.object.new_record? } }
  = f.hidden_field :_destroy
  .row
    .col-sm-5
      = f.input :device_id, collection: Device.all, include_blank: "Select Device...", label: false, input_html: { data: { controller: "select", reload: true }}
    .col-sm-4
      = f.input :variable_name, label: false, input_html: { placeholder: "Variable Name", data: { reload: true }}
    .col-sm-2.mt-2
      = f.input :trigger, wrapper_html: { class: "single-checkbox" }
    .col-sm-1.mt-2
      = link_to fa_icon("trash"), "#", class: "remove_fields", data: { action: "nested-form#remove" }
