- type ||= :notice
- bg_class = type.to_sym == :alert ? "text-bg-danger" : "text-bg-success"
.toast.align-items-center.border-0{ class: bg_class, role: "alert", "aria-live": "assertive", "aria-atomic": "true", data: { controller: "toast" } }
  .d-flex
    .toast-body= message
    %button.btn-close.btn-close-white.me-2.m-auto{ type: "button", "data-bs-dismiss": "toast", "aria-label": "Close" }
