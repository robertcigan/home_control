.table-responsive
  %table.table.table-hover.table-striped
    %thead
      %tr
        %th= sort_link @search, :name, "Name"
        %th= sort_link @search, :device_type, "Type"
        %th.text-center Value
        %th.text-center= sort_link @search, :updated_at, "Last Change"
        %th= sort_link @search, :board_name, "Board"
        %th= sort_link @search, :pin, "Pin"
        %th= sort_link @search, :pin, "Address"
        %th= sort_link @search, :compression_type, "Compression"
        %th
        %th
    %tbody
      - @devices.each do |device|
        %tr.device{ id: dom_id(device), data: { device: device.json_data }}
          %td= link_to device, device_path(device), class: "indicated", data: { turbo_frame: "_top" }
          %td= device.device_type_to_human
          %td.text-center.indication= device.indication
          %td.text-center.updated= device.last_change_text
          %td= device.board
          %td= device.pin
          %td= device.holding_register_address
          %td= device.compression_type_to_human
          %td.text-nowrap.text-end
            - if device.toggle?
              = link_to fa_icon("toggle-off"), set_device_path(device, device: { value: true }), class: "btn btn-sm btn-warning toggle-off", data: { controller: "remote-action", turbo_method: :patch }
              = link_to fa_icon("toggle-on"), set_device_path(device, device: { value: false }), class: "btn btn-sm btn-success toggle-on", data: { controller: "remote-action", turbo_method: :patch }
          %td.text-nowrap.text-end.actions
            = link_to fa_icon("pencil-alt"), edit_device_path(device), title: "Edit", class: "btn btn-sm btn-primary", data: { turbo_frame: "_top" }
            = link_to fa_icon("trash"), device_path(device), class: "ml btn btn-sm btn-danger", data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }

.page-pagination
  .pagination-description
    = page_entries_info @devices
  = paginate @devices
