.table-responsive
  %table.table.table-hover.table-striped.table-condensed
    %thead
      %tr
        %th= sort_link @search, :name, "Name"
        %th.text-center= sort_link @search, :public_access, "Public Access"
        %th
    %tbody
      - @panels.each do |panel|
        %tr{ id: dom_id(panel) }
          %td= link_to panel, panel, data: { turbo: false }
          %td.text-center= panel.public_access? ? fa_icon("check") : nil
          %td.text-nowrap.text-end.actions
            = link_to fa_icon("columns"), panel_widgets_path(panel), title: "Layout", class: "btn btn-sm btn-warning", data: { turbo_frame: "_top" }
            = link_to fa_icon("pencil-alt"), edit_panel_path(panel), title: "Edit", class: "btn btn-sm btn-primary", data: { turbo_frame: "_top" }
            = link_to fa_icon("trash"), panel, class: "ml btn btn-sm btn-danger", data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }

.page-pagination
  .pagination-description
    = page_entries_info @panels
  = paginate @panels
