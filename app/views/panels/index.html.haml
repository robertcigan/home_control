- page_title "Panels"

- content_for(:action_button) do
  = link_to fa_icon("plus", class: "pe-2", text: "Add Panel"), new_panel_path, class: "btn btn-primary"

= turbo_frame_tag "panels" do
  = simple_form_for @search, url: panels_path, method: :get, wrapper: :inline_form, html: { id: "panel_search", class: "d-flex flex-wrap gap-2 mb-2", data: { controller: "search-form autosubmit" } } do |form|
    = form.search_field :name_cont, placeholder: "Search by Name", class: "form-control search-field"
    = render "common/per_page"

  = render "panels"
