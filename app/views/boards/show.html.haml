- page_title @board

- content_for(:section_title) do
  .card.shadow.board{ data: { board: @board.json_data }}
    .card-body.pt-0
      .card-title.border-bottom.pt-2.pb-2.d-flex.align-items-center
        %h1= @board.name
        .actions.ms-auto
          = link_to fa_icon("pencil-alt"), edit_board_path(@board), title: "Edit", class: "btn btn-sm btn-primary"
          = link_to fa_icon("trash"), @board, class: "ml btn btn-sm btn-danger", data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }
      .row.py-2
        .col-sm-3.col-6
          IP
        .col-sm-9.col-6
          = @board.ip
      .row.py-2
        .col-sm-3.col-6
          Type
        .col-sm-9.col-6
          = @board.board_type_to_human
      - if @board.board_type_modbus_tcp?
        .row.py-2
          .col-sm-3.col-6
            Address
          .col-sm-9.col-6
            = @board.slave_address
      .row.py-2
        .col-sm-3.col-6
          Status
        .col-sm-9.col-6
          = fa_icon("check", class: "connected")
          = fa_icon("ban", class: "disconnected")
      - if @board.board_type_esp? || @board.board_type_arduino_mega_8b?
        .row.py-2
          .col-sm-3.col-6
            FW Version
          .col-sm-9.col-6
            = @board.version
      - if @board.board_type_esp?
        .row.py-2
          .col-sm-3.col-6
            SSID
          .col-sm-9.col-6.ssid
            = @board.ssid
        .row.py-2
          .col-sm-3.col-6
            Signal Strength
          .col-sm-9.col-6
            %span.signal-strength
              = @board.signal_strength
            \%

= turbo_frame_tag "board_chart", src: chart_board_board_logs_path(@board), loading: :lazy
= turbo_frame_tag "board_logs", src: board_board_logs_path(@board), loading: :lazy
